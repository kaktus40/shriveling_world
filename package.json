{
    "name": "testsapper",
    "version": "1.0.0",
    "type": "module",
    "description": "The default template for setting up a [Sapper](https://github.com/sveltejs/sapper) project. Can use either Rollup or webpack as bundler.",
    "main": "rollup.config.js",
    "scripts": {
        "dev": "vite dev",
        "build": "npm run build:datasets && vite build",
        "preview": "vite preview",
        "build:datasets": "node scripts/build-datasets.mjs",
        "test": "tsx --test tests/unit/**/*.test.ts",
        "validate": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "fixtures:create": "tsx scripts/create-reduced-dataset-fixtures.ts",
        "characterize:datasets": "npm run fixtures:create && tsx scripts/characterize-datasets.ts"
    },
    "dependencies": {
        "@types/three": "^0.184.1",
        "bulma": "^1.0.4",
        "check-peer-dependencies": "^4.3.4",
        "compression": "^1.8.1",
        "delaunator": "^5.1.0",
        "moveable": "^0.53.0",
        "polka": "next",
        "sirv": "^3.0.2"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/plugin-transform-runtime": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/runtime": "^7.29.7",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@rollup/plugin-babel": "^7.1.0",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-replace": "^6.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@rollup/plugin-url": "^8.0.2",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.63.0",
        "@tsconfig/svelte": "^5.0.8",
        "@types/compression": "^1.8.1",
        "@types/dat.gui": "^0.7.13",
        "@types/geojson": "^7946.0.16",
        "@types/node": "^25.9.1",
        "@types/pako": "^2.0.4",
        "@types/papaparse": "^5.5.2",
        "@types/polka": "^0.5.8",
        "@types/webgl2": "^0.0.12",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "autoprefixer": "^10.5.0",
        "cssnano": "^8.0.1",
        "dat.gui": "^0.7.9",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "fa-svelte": "^3.1.0",
        "file-saver": "^2.0.5",
        "fs-extra": "^11.3.5",
        "glob": "^13.0.6",
        "glslify": "^7.1.1",
        "jszip": "^3.10.1",
        "pako": "^2.1.0",
        "papaparse": "^5.5.3",
        "poly2tri": "^1.5.0",
        "postcss": "^8.5.15",
        "postcss-discard-comments": "^8.0.0",
        "prettier": "^3.8.3",
        "purgecss": "^8.0.0",
        "rollup": "^4.61.1",
        "rollup-plugin-modify": "^3.0.0",
        "svelte": "^5.56.1",
        "svelte-check": "^4.6.0",
        "three": "^0.184.0",
        "tocbot": "^4.36.8",
        "tslib": "^2.8.1",
        "tsx": "^4.22.4",
        "twgl.js": "^7.0.0",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "yargs": "^18.0.0"
    },
    "browserslist": [
        "last 1 version",
        "> 0.5%"
    ],
    "toCopy": [
        {
            "in": "./src/toStatic/",
            "out": "./static/"
        },
        {
            "in": "./markdown/assets/",
            "out": "./static/assets/"
        },
        {
            "in": "./node_modules/bulma/css/bulma.css",
            "out": "./static/bulma.css"
        }
    ],
    "author": "",
    "license": "ISC"
}
