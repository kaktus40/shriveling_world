@startuml
title Graphe de calcul WebGPU pour cones et courbes

skinparam componentStyle rectangle

database "Buffers GPU statiques\nsommetsECEF\nned2ECEF\ntownOverlaps\nlimites\ncontroles courbes" as staticBuffers
database "Buffers GPU dynamiques\ncityLinks[annee]\ncitiesDict[annee]\nroadAlpha[annee]\nhauteurs courbes[annee]" as dynamicBuffers

component "Passe Cones Bruts WGSL\nEntree: statique + dynamique\nSortie: buffer cones bruts" as raw
component "Passe Intersections Cone/Cone WGSL\nEntree: cones bruts + townOverlaps\nSortie: buffer cones decoupes" as ciseled
component "Passe Decoupe Par Limites WGSL\nEntree: cones decoupes + limites\nSortie: buffer cones finaux" as final
component "Passe Geometrie Courbes WGSL\nEntree: controles + hauteurs dynamiques\nSortie: buffer vertices courbes" as curve
component "Couche Cones Babylon\nEntree: buffer cones finaux" as coneLayer
component "Couche Courbes Babylon\nEntree: buffer vertices courbes" as curveLayer

staticBuffers --> raw
dynamicBuffers --> raw
raw --> ciseled
staticBuffers --> ciseled
ciseled --> final
staticBuffers --> final
staticBuffers --> curve
dynamicBuffers --> curve
final --> coneLayer
curve --> curveLayer

note bottom of raw
  Parallelisation naturelle:
  tache = cityIndex x echantillonAzimut.
end note

note bottom of ciseled
  Passe critique:
  intersections cone/cone
  bornees par townOverlaps.
end note
@enduml
