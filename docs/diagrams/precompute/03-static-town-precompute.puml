@startuml
title Detail prepareStaticTownPrecompute

|CPU - PreparedDataset|
start
:cities[] avec cityIndex, cityCode, lon, lat;
:options: neighborSectors, neighborLimit;

|CPU - Referential|
:buildCityMap();
:buildLocalReferentials();
:compute summitECEF + ned2ECEF rows;

|CPU or GPU candidate - Pair geometry|
:for each ordered pair cityA/cityB;
:compute azimuth A->B;
:compute azimuth B->A;
:compute angular distance theta;
:compute midpoint;
:compute pointP and pointQ;
:compute local unit vector and elevation;

|CPU - Neighbor selection|
:partition candidates by angular sector;
:sort candidates by distance inside each sector;
:select bounded neighborLimit;
:sort selected neighbors by azimuth;

|CPU - StaticTownPrecompute|
:cityMap;
:citiesGlslDatas;
:azDistMid stride 4;
:pointPPointQ stride 4;
:vUnitAndElevation stride 4;
:townOverlaps stride 3;
:neighborLimit;
stop
@enduml
